{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "dev": "node dev.mjs",
    "build": "npm run build --workspace=@workspace/royal-kesar && npm run build --workspace=@workspace/api-server",
    "start": "NODE_ENV=production PORT=5001 node --enable-source-maps dist/index.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
